{
  "name": "GTD Personal",
  "purpose": "Getting Things Done personal productivity",
  "categoryOrdering": [
    "missing-outcome",
    "missing-next-action",
    "missing-timeframe",
    "missing-context",
    "missing-reference"
  ],
  "supportedAtomTypes": ["task", "fact", "event", "decision", "insight"],
  "questionTemplates": {
    "missing-outcome": {
      "question": "What's the desired outcome?",
      "options": {
        "task": [
          "Complete {topic}",
          "Resolve {topic} issue",
          "Get {topic} approved",
          "{freeform}"
        ],
        "decision": [
          "Choose between options for {topic}",
          "Finalize {topic} decision",
          "Evaluate {topic} tradeoffs",
          "{freeform}"
        ],
        "event": [
          "Attend {topic}",
          "Prepare for {topic}",
          "Follow up after {topic}",
          "{freeform}"
        ],
        "_default": [
          "Complete {topic}",
          "Resolve {topic}",
          "Clarify {topic}",
          "{freeform}"
        ]
      }
    },
    "missing-next-action": {
      "question": "What's the very next physical action?",
      "options": {
        "task": [
          "Call {person} about {topic}",
          "Email {person} about {topic}",
          "Research {topic} online",
          "{freeform}"
        ],
        "decision": [
          "List pros and cons for {topic}",
          "Ask {person} for input on {topic}",
          "Set a deadline to decide on {topic}",
          "{freeform}"
        ],
        "_default": [
          "Look up {topic}",
          "Ask {person} about {topic}",
          "Write down thoughts on {topic}",
          "{freeform}"
        ]
      }
    },
    "missing-timeframe": {
      "question": "By when does this need to happen?",
      "options": {
        "_default": [
          "Today",
          "This week",
          "This month",
          "No deadline",
          "{freeform}"
        ]
      }
    },
    "missing-context": {
      "question": "Where or when would you do this?",
      "options": {
        "task": [
          "At home",
          "At work",
          "At computer",
          "On the phone",
          "{freeform}"
        ],
        "_default": [
          "At home",
          "At work",
          "While commuting",
          "{freeform}"
        ]
      }
    },
    "missing-reference": {
      "question": "Is there a related person, project, or resource?",
      "options": {
        "task": [
          "Related to {topic} project",
          "Depends on {person}",
          "See {topic} notes",
          "{freeform}"
        ],
        "_default": [
          "Related to {topic}",
          "Involves {person}",
          "See reference material",
          "{freeform}"
        ]
      }
    }
  },
  "backgroundCloudEnrichment": false,
  "followUpTemplates": {
    "missing-outcome": {
      "question": "You said the outcome is \"{prior_answer}\". Can you be more specific?",
      "options": {
        "task": [
          "What does done look like for {prior_answer}?",
          "Who needs to approve {prior_answer}?",
          "How will you know {prior_answer} succeeded?",
          "{freeform}"
        ],
        "decision": [
          "What criteria will confirm {prior_answer} was the right call?",
          "What risks exist if {prior_answer} fails?",
          "Who is affected by {prior_answer}?",
          "{freeform}"
        ],
        "_default": [
          "What does done look like for {prior_answer}?",
          "How will you measure success of {prior_answer}?",
          "What would make {prior_answer} fail?",
          "{freeform}"
        ]
      }
    },
    "missing-next-action": {
      "question": "You said the next action is \"{prior_answer}\". What comes right after that?",
      "options": {
        "task": [
          "After {prior_answer}, what is the following step?",
          "Do you need anything before you can do {prior_answer}?",
          "Who else needs to act after {prior_answer}?",
          "{freeform}"
        ],
        "_default": [
          "What happens right after {prior_answer}?",
          "Is there a prerequisite for {prior_answer}?",
          "Who else is involved in {prior_answer}?",
          "{freeform}"
        ]
      }
    },
    "missing-timeframe": {
      "question": "You said the timeframe is \"{prior_answer}\". Can you narrow that down?",
      "options": {
        "_default": [
          "What specific date or week for {prior_answer}?",
          "Is {prior_answer} a hard deadline or flexible?",
          "What happens if {prior_answer} slips?",
          "{freeform}"
        ]
      }
    },
    "missing-context": {
      "question": "You said the context is \"{prior_answer}\". Anything more specific?",
      "options": {
        "task": [
          "What tools or resources do you need at {prior_answer}?",
          "Is {prior_answer} the only place you can do this?",
          "What time of day works best at {prior_answer}?",
          "{freeform}"
        ],
        "_default": [
          "What tools do you need at {prior_answer}?",
          "Is {prior_answer} the only option?",
          "What conditions are needed at {prior_answer}?",
          "{freeform}"
        ]
      }
    },
    "missing-reference": {
      "question": "You mentioned \"{prior_answer}\" as a reference. Any related resources?",
      "options": {
        "task": [
          "Are there other documents related to {prior_answer}?",
          "Who else is connected to {prior_answer}?",
          "Is {prior_answer} part of a larger project?",
          "{freeform}"
        ],
        "_default": [
          "What else is related to {prior_answer}?",
          "Who else should know about {prior_answer}?",
          "Is there a follow-up for {prior_answer}?",
          "{freeform}"
        ]
      }
    }
  }
}
